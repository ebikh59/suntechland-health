---
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  author?: string;
}

const { title, excerpt, date, category, slug, image, author } = Astro.props;
const formattedDate = date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
---

<article class="featured">
  {image && (
    <a href={`/post/${slug}`} class="featured-img-wrap">
      <img src={image} alt={title} loading="eager" />
      <div class="featured-overlay"></div>
    </a>
  )}
  <div class="featured-body">
    <div class="featured-meta">
      <span class="featured-label">Featured</span>
      <CategoryBadge category={category} />
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <h2><a href={`/post/${slug}`}>{title}</a></h2>
    <p class="excerpt">{excerpt}</p>
    <div class="featured-footer">
      <span class="author">By {author ?? 'SunTechLand Staff'}</span>
      <a href={`/post/${slug}`} class="read-btn">Read Article →</a>
    </div>
  </div>
</article>

<style>
.featured {
  background: var(--card);
  border: 1px solid var(--accent);
  border-radius: 12px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 320px;
  box-shadow: 0 0 30px color-mix(in srgb, var(--accent) 8%, transparent);
}
@media (max-width: 768px) {
  .featured { grid-template-columns: 1fr; }
}
.featured-img-wrap {
  position: relative;
  display: block;
  overflow: hidden;
}
.featured-img-wrap img {
  width: 100%; height: 100%; object-fit: cover;
}
.featured-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to right, transparent 60%, var(--card));
}
@media (max-width: 768px) {
  .featured-overlay { background: linear-gradient(to top, var(--card) 0%, transparent 60%); }
  .featured-img-wrap { max-height: 220px; }
}
.featured-body {
  padding: 2rem;
  display: flex; flex-direction: column; gap: 1rem; justify-content: center;
}
.featured-body:only-child {
  grid-column: 1 / -1;
}
.featured-meta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.featured-label {
  background: var(--accent);
  color: #000;
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
}
.featured-meta time { font-size: 0.78rem; color: var(--muted); }
h2 { font-size: 1.6rem; font-weight: 800; line-height: 1.3; }
h2 a { color: var(--text); }
h2 a:hover { color: var(--accent); }
.excerpt { color: var(--subtle); font-size: 0.95rem; line-height: 1.6; }
.featured-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 0.5rem; }
.author { font-size: 0.82rem; color: var(--muted); }
.read-btn {
  background: var(--accent);
  color: #000;
  font-weight: 700;
  font-size: 0.85rem;
  padding: 0.5rem 1.1rem;
  border-radius: 6px;
  transition: opacity 0.2s;
}
.read-btn:hover { opacity: 0.85; color: #000; }
</style>
