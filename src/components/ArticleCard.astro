---
import CategoryBadge from './CategoryBadge.astro';
import SeverityBadge from './SeverityBadge.astro';

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  author?: string;
  severity?: string;
}

const { title, excerpt, date, category, slug, image, author, severity } = Astro.props;
const formattedDate = date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
const sevClass = severity ? `s-${severity.toLowerCase()}` : 's-none';
---

<article class={`case ${sevClass}`}>
  <div class="case-triage">
    {severity && <SeverityBadge severity={severity} />}
  </div>

  <div class="case-body">
    <h3><a href={`/post/${slug}`}>{title}</a></h3>
    <p class="excerpt">{excerpt}</p>
    <div class="case-tags">
      <CategoryBadge category={category} />
    </div>
  </div>

  <div class="case-chart">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <span class="author">{author ?? 'SunTechLand Staff'}</span>
  </div>
</article>

<style>
/* Triage case row — severity spine encodes state in form, not just colour */
.case {
  display: grid;
  gap: 0.4rem 1rem;
  grid-template-columns: 1fr;
  padding: 1.05rem 1.1rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--border);
  border-radius: 4px;
  transition: background 0.15s, border-color 0.15s;
}
.case:hover { background: var(--card); border-color: color-mix(in srgb, var(--accent) 45%, transparent); }

.case.s-critical { border-left-color: var(--crit); }
.case.s-high     { border-left-color: var(--high); }
.case.s-medium   { border-left-color: var(--med); }
.case.s-low      { border-left-color: var(--low); }

@container (min-width: 660px) {
  .case { grid-template-columns: 104px 1fr 132px; align-items: start; }
  .case-chart { text-align: right; }
}

.case-triage { padding-top: 0.15rem; }

.case-body { display: flex; flex-direction: column; gap: 0.45rem; min-width: 0; }
h3 {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  line-height: 1.28;
  letter-spacing: -0.01em;
  text-wrap: balance;
}
h3 a { color: var(--text); }
h3 a:hover { color: var(--accent); }
.excerpt {
  font-size: 0.875rem;
  color: var(--subtle);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.case-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }

.case-chart {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  font-family: var(--font-mono);
  font-size: 0.71rem;
  color: var(--muted);
  letter-spacing: 0.03em;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}
</style>
