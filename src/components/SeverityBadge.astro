---
const { severity } = Astro.props as { severity?: string };
if (!severity) return;

const map: Record<string, string> = {
  Critical: 'var(--crit)',
  High:     'var(--high)',
  Medium:   'var(--med)',
  Low:      'var(--low)',
};
const color = map[severity] ?? 'var(--muted)';
---

<span class="severity-badge" style={`--c: ${color}`}>{severity}</span>

<style>
/* Clinical triage tag — semantic colour, deliberately separate from the accent */
.severity-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-family: var(--font-mono);
  font-size: 0.69rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c);
}
.severity-badge::before {
  content: '';
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: currentColor;
}
</style>
