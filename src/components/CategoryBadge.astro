---
const { category } = Astro.props as { category: string };

const map: Record<string, { label: string; color: string }> = {
  'hipaa-compliance':        { label: 'HIPAA & Compliance', color: '#00d4ff' },
  'hospital-attacks':        { label: 'Hospital Attacks',   color: '#ef4444' },
  'medical-device-security': { label: 'Medical Devices',    color: '#f97316' },
  'patient-data-breaches':   { label: 'Patient Data',       color: '#eab308' },
  'healthcare-threat-intel': { label: 'Threat Intel',       color: '#a855f7' },
  'health-it-security':      { label: 'Health IT',          color: '#22c55e' },
};

const { label, color } = map[category] ?? { label: category, color: '#94a3b8' };
---

<span class="badge" style={`--c: ${color}`}>{label}</span>

<style>
.badge {
  display: inline-block;
  padding: 0.2rem 0.65rem;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--c);
  background: color-mix(in srgb, var(--c) 12%, transparent);
  border: 1px solid color-mix(in srgb, var(--c) 30%, transparent);
}
</style>
